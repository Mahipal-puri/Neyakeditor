# NeyakEditor — environment variables
# Copy this file to `.env` (which is gitignored) and fill in the values.
# Restart `npm run dev` after changing values.

# -------------------------------------------------------------------
# Replicate — required for AI background removal in the editor.
# Get a token at: https://replicate.com/account/api-tokens
# Free trial credits available; per-call pricing after.
# -------------------------------------------------------------------
REPLICATE_API_TOKEN=

# Optional override — change the model used for background removal.
# Default: 851-labs/background-remover  (current state-of-art on Replicate)
# Other options: cjwbw/rembg, lucataco/remove-bg
REPLICATE_BG_MODEL=851-labs/background-remover

# -------------------------------------------------------------------
# Unsplash — optional. When set, /api/templates merges 12 real photo
# templates from Unsplash into the gradient catalog so users can start
# editing actual photos. Without it, only the local gradient templates
# are returned. Get a key (free) at:
# https://unsplash.com/developers
# -------------------------------------------------------------------
UNSPLASH_ACCESS_KEY=

# Optional override — the Unsplash search query used for templates.
# Default: "abstract,design,art,texture"
UNSPLASH_TEMPLATES_QUERY=abstract,design,art,texture
