# NeyakEditor — environment variables
# Copy this file to `.env` (which is gitignored) and fill in the values.
# Restart `npm run dev` after changing values.

# -------------------------------------------------------------------
# Replicate — required for AI background removal in the editor.
# Get a token at: https://replicate.com/account/api-tokens
# Free trial credits available; per-call pricing after.
# -------------------------------------------------------------------
REPLICATE_API_TOKEN=

# Optional override — change the model used for background removal.
# Default: 851-labs/background-remover  (current state-of-art on Replicate)
# Other options: cjwbw/rembg, lucataco/remove-bg
REPLICATE_BG_MODEL=851-labs/background-remover

# -------------------------------------------------------------------
# Unsplash — optional. When set, /api/templates merges 12 real photo
# templates from Unsplash into the gradient catalog so users can start
# editing actual photos. Without it, only the local gradient templates
# are returned. Get a key (free) at:
# https://unsplash.com/developers
# -------------------------------------------------------------------
UNSPLASH_ACCESS_KEY=

# Optional override — the Unsplash search query used for templates.
# Default: "abstract,design,art,texture"
UNSPLASH_TEMPLATES_QUERY=abstract,design,art,texture

# -------------------------------------------------------------------
# Replicate — models used by the editor's "AI styles" card (Ghibli,
# Anime, Cartoon, Sketch). All models must accept `{ image, prompt }`.
#
# Two configuration styles, can be mixed:
#
# Option A — ONE model for all four styles. Simplest:
#   REPLICATE_STYLE_MODEL=black-forest-labs/flux-kontext-pro
#
# Option B — per-style dedicated models for best results. Each blank one
# falls back to REPLICATE_STYLE_MODEL above:
#   REPLICATE_GHIBLI_MODEL=<a ghibli-fine-tuned model>
#   REPLICATE_ANIME_MODEL=<an anime-fine-tuned model>
#   REPLICATE_CARTOON_MODEL=<a cartoon img2img model>
#   REPLICATE_SKETCH_MODEL=<a sketch img2img model>
#
# Leave ALL blank to disable the Replicate path — the editor falls back
# to local image-processing (Sobel edges, posterize, bloom) so the
# buttons still produce a visible effect without API credits.
#
# Browse https://replicate.com/explore — search "ghibli", "anime img2img",
# "style transfer" — and paste a model path (`user/model-name`) below.
# -------------------------------------------------------------------
REPLICATE_STYLE_MODEL=
REPLICATE_GHIBLI_MODEL=
REPLICATE_ANIME_MODEL=
REPLICATE_CARTOON_MODEL=
REPLICATE_SKETCH_MODEL=
REPLICATE_WATERCOLOR_MODEL=
REPLICATE_OILPAINT_MODEL=
REPLICATE_POPART_MODEL=
REPLICATE_PIXELART_MODEL=
